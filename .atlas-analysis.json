  "keyFeatures": [
    "Multi-account OAuth pool with health-aware selection and automatic failover",
    "Interactive terminal dashboard for account login, switching, and diagnostics",
    "Forecast, report, fix, and doctor commands for operational safety",
    "Project-scoped account storage with global defaults",
    "Proactive refresh and preemptive quota deferral controls",
    "Session affinity and live account sync for reduced account thrashing",
    "Safe storage migrations with backup and WAL write strategy",
    "Configurable terminal themes with hotkey navigation"
  ],
  "publicApiSurface": [
    "codex auth login",
    "codex auth list",
    "codex auth status",
    "codex auth switch <index>",
    "codex auth check",
    "codex auth features",
    "codex auth verify-flagged",
    "codex auth forecast [--live] [--model <model>] [--json]",
    "codex auth report [--live] [--json] [--out <path>]",
    "codex auth fix [--dry-run] [--live] [--model <model>] [--json]",
    "codex auth doctor [--fix] [--dry-run] [--json]"
  ]
